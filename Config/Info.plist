<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Only exempt encryption is used (HTTPS/ATS, Keychain). Declared here so
	     TestFlight/App Store uploads skip the export-compliance questionnaire. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
	<!-- Bonjour service types the app browses with NWBrowser. Without _smb._tcp here,
	     browsing it fails with -65555 (kDNSServiceErr_NoAuth): the SMB add-server
	     discovery picker. (Jellyfin discovery is UDP broadcast, not Bonjour, so it
	     needs no entry.) Distinct from the multicast entitlement, which gates raw
	     broadcast sockets, not Bonjour browsing. -->
	<key>NSBonjourServices</key>
	<array>
		<string>_smb._tcp</string>
	</array>
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
	</array>
	<!-- Launch screen painted in the launch animation's field color (mid stop),
	     so the system launch screen → first animation frame handoff is seamless:
	     the story's t=0 draws nothing but the field (rings fade in from 0).
	     Color lives in LaunchBackground.colorset; keep in sync with LaunchPalette. -->
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
	</dict>
</dict>
</plist>
